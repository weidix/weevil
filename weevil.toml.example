# Weevil configuration example
# Priority: CLI args > mode section > shared section

[shared]
# Reusable defaults for all modes
# use `script` for single source, or `scripts` for ordered multi-source list
scripts = ["scripts/source_primary.lua", "scripts/source_secondary.lua"]
output = "./library/{title}"
input-name-rule = [
  "1080p,WEB-DL",
  "regex:\\[[^\\]]+\\]",
  "replace:_=> "
]
folder-multi = "first" # first | hard-link | soft-link
max-depth = -1
fetch-threads = 1 # 1=serial, >1=parallel limit, 0=unlimited
throttle-same-script = false # add ~1000ms random delay and prevent same-script overlap across tasks
script-throttle-base-ms = 1000 # effective wait ~= base ±100ms
multi-source = false # false: stop at first successful script; true: aggregate successful sources
save-images = false # download and save remote poster/fanart images locally
multi-source-max-sources = 2 # stop after N successful sources when multi-source=true; 0 means unlimited
node-mapping-csv = ["./node_mapping_base.csv", "./node_mapping_extra.csv"] # optional CSV mapping files: node,to,from... (later files override earlier ones)

[shared.source-priority]
# Optional source priority by script alias
# images: poster/fanart fields
# details: title/runtime/premiered and most textual metadata
images = ["source_primary", "source_secondary"]
details = ["source_primary"]

[shared.translation]
# Optional translation configuration. If keys is empty, translation is disabled.
target-lang = "en"
keys = ["title", "originaltitle", "plot"]

# Configure one endpoint.
[shared.translation.endpoints]
kind = "openai"
url = "https://example.invalid/v1/chat/completions"
api-key = "REPLACE_WITH_KEY"
model = "gpt-translation"

# To switch endpoint type, replace the block above with:
# [shared.translation.endpoints]
# kind = "google-free"

[name]
# name mode output file path (NFO)
output = "./output/name-mode.nfo"
# save-images = true

[file]
# file mode-specific overrides (optional)
# folder-multi = "hard-link"

# [file.source-priority]
# images = ["source_secondary", "source_primary"]
# details = ["source_primary"]

[dir]
input = "./videos"
# max-depth = 2
# fetch-threads = 4
# throttle-same-script = true
# script-throttle-base-ms = 1200

[watch]
input = "./incoming"
# max-depth = -1
# fetch-threads = 4
# throttle-same-script = true
# script-throttle-base-ms = 1200
